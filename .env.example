NODE_ENV=production
PORT=3000
DATA_DIR=/app/data
WEB_DIST_DIR=/app/apps/web/dist
APP_SECRET=replace-with-random-64-char-secret
PROCESSING_MODE=queued
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute

# Hardening knobs for the next production pass.
TRUST_PROXY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=true
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW=1 minute
UPLOAD_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW=1 minute
ASK_RATE_LIMIT_MAX=60
ASK_RATE_LIMIT_WINDOW=1 minute
UPLOAD_MAX_BYTES=26214400
UPLOAD_MAX_FILES=8
CORS_ORIGINS=
CSRF_HEADER_NAME=x-csrf-token
APP_LOG_LEVEL=info
HEALTH_CHECK_TIMEOUT_MS=2000
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
CONTENT_SECURITY_POLICY=
ALLOW_PRIVATE_OUTBOUND_URLS=

# Optional. When set, API stores app state in PostgreSQL instead of DATA_DIR/store.json.
DATABASE_URL=postgres://rag_ocr:password@localhost:5432/rag_ocr
POSTGRES_MIGRATIONS_DIR=

# Queue / worker.
REDIS_URL=redis://redis:6379
REDIS_PORT=6379
WORKER_CONCURRENCY=2
WORKER_JOB_ATTEMPTS=5
WORKER_JOB_BACKOFF_MS=5000
WORKER_LOG_LEVEL=info
DOCUMENT_PIPELINE_VERSION=1

# Object storage.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=rag_ocr
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET_SOURCE=rag-ocr-source
S3_BUCKET_DERIVED=rag-ocr-derived
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=rag_ocr
MINIO_ROOT_PASSWORD=change-me

# RAG retrieval settings.
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_COLLECTION=rag_ocr_chunks
VECTOR_SEARCH_LIMIT=12
RAG_REQUEST_TIMEOUT_MS=15000
ANSWER_MAX_CONTEXT_CHARS=7000
ANSWER_MAX_OUTPUT_TOKENS=700
QDRANT_BASE_URL=http://localhost:6333
QDRANT_API_KEY=
TEI_BASE_URL=http://localhost:8080

# Optional service ports exposed on the host.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
