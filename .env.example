NODE_ENV=production
PORT=3000
DATA_DIR=/app/data
WEB_DIST_DIR=/app/apps/web/dist
APP_SECRET=replace-with-random-64-char-secret
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute

# Optional. When set, API stores app state in PostgreSQL instead of DATA_DIR/store.json.
DATABASE_URL=postgres://rag_ocr:password@localhost:5432/rag_ocr
