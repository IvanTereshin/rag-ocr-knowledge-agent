NODE_ENV=production
APP_PORT=3000
APP_SECRET=replace-with-random-64-char-secret
POSTGRES_PASSWORD=replace-with-random-postgres-password
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute

# Hardening knobs for the next production pass.
TRUST_PROXY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=true
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW=1 minute
UPLOAD_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW=1 minute
ASK_RATE_LIMIT_MAX=60
ASK_RATE_LIMIT_WINDOW=1 minute
UPLOAD_MAX_BYTES=26214400
UPLOAD_MAX_FILES=8
CORS_ORIGINS=https://example.com
CSRF_HEADER_NAME=x-csrf-token
APP_LOG_LEVEL=info

# Optional service ports exposed on the host.
QDRANT_PORT=6333
TEI_PORT=8080

# ARM64 works well on the current Mac/OrbStack dev server.
# For amd64 Linux, use the matching TEI CPU image.
TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-arm64-latest
TEI_RERANKER_MODEL=BAAI/bge-reranker-base

# RAG retrieval settings.
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_COLLECTION=rag_ocr_chunks
VECTOR_SEARCH_LIMIT=12
RAG_REQUEST_TIMEOUT_MS=15000
