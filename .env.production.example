NODE_ENV=production
APP_PORT=3000
APP_SECRET=replace-with-random-64-char-secret
POSTGRES_PASSWORD=replace-with-random-postgres-password
POSTGRES_MIGRATIONS_DIR=
PROCESSING_MODE=queued
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute

# Hardening knobs for the next production pass.
TRUST_PROXY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW=1 minute
UPLOAD_RATE_LIMIT_MAX=20
UPLOAD_RATE_LIMIT_WINDOW=1 minute
ASK_RATE_LIMIT_MAX=60
ASK_RATE_LIMIT_WINDOW=1 minute
UPLOAD_MAX_BYTES=26214400
UPLOAD_MAX_FILES=8
UPLOAD_SCAN_ENABLED=false
UPLOAD_SCAN_TIMEOUT_MS=30000
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CORS_ORIGINS=https://example.com
CSRF_HEADER_NAME=x-csrf-token
APP_LOG_LEVEL=info
HEALTH_CHECK_TIMEOUT_MS=2000
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=true
CONTENT_SECURITY_POLICY=
ALLOW_PRIVATE_OUTBOUND_URLS=false

# Optional service ports exposed on the host.
QDRANT_PORT=6333
TEI_PORT=8080
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ARM64 works well on the current Mac/OrbStack dev server.
# For amd64 Linux, use the matching TEI CPU image.
TEI_IMAGE=ghcr.io/huggingface/text-embeddings-inference:cpu-arm64-latest
TEI_RERANKER_MODEL=BAAI/bge-reranker-base

# Queue / worker.
REDIS_URL=redis://redis:6379
WORKER_CONCURRENCY=2
WORKER_JOB_ATTEMPTS=5
WORKER_JOB_BACKOFF_MS=5000
WORKER_LOG_LEVEL=info
DOCUMENT_PIPELINE_VERSION=1

# Object storage.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=rag_ocr
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET_SOURCE=rag-ocr-source
S3_BUCKET_DERIVED=rag-ocr-derived
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=rag_ocr
# Compose uses S3_SECRET_ACCESS_KEY as the MinIO root password for this demo profile.
MINIO_ROOT_PASSWORD=change-me

# RAG retrieval settings.
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_COLLECTION=rag_ocr_chunks
VECTOR_SEARCH_LIMIT=12
RAG_REQUEST_TIMEOUT_MS=15000
ANSWER_MAX_CONTEXT_CHARS=7000
ANSWER_MAX_OUTPUT_TOKENS=700
MISTRAL_OCR_BASE_URL=https://api.mistral.ai/v1
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_OCR_API_KEY=
OCR_REQUEST_TIMEOUT_MS=60000
QDRANT_BASE_URL=http://qdrant:6333
QDRANT_API_KEY=
TEI_BASE_URL=http://tei:80
